{
    "uid": "http-overview",
    "title": "HTTP Overview",
    "timezone": "browser",
    "refresh": "10s",
    "time": {
        "from": "now-30m",
        "to": "now"
    },
    "panels": [
        {
            "title": "Request Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "sum(rate(http_server_requests_total[1m]))",
                    "legendFormat": "req/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            }
        },
        {
            "title": "Request Duration p95",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "p95"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            }
        },
        {
            "title": "Error Rate (5xx)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "sum(rate(http_server_requests_total{http_response_status_class=\"5xx\"}[1m]))",
                    "legendFormat": "5xx/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            }
        },
        {
            "title": "Active Requests",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "http_server_active_requests",
                    "legendFormat": "active"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "none"
                }
            }
        },
        {
            "title": "Response Size p95",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_server_response_size_bytes_bucket[5m])) by (le))",
                    "legendFormat": "p95"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes"
                }
            }
        },
        {
            "title": "Response Rate by Route",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": ""
            },
            "targets": [
                {
                    "expr": "sum(rate(http_server_request_total[1m])) by (http_route)",
                    "legendFormat": "{{http_route}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            }
        }
    ],
    "schemaVersion": 39
}